{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run Task",
      "type": "shell",
      "command": "uv",
      "group": {
        "kind": "build",
        "args": ["run", "python", "utils/run.py"],
        "isDefault": false
      }
    },
    {
      "label": "Test Current",
      "type": "shell",
      "command": "uv",
      "args": ["run", "pytest", "tests/tests_one.py", "-v"],
      "group": {
        "kind": "build",
        "isDefault": false
      }
    },
    {
      "label": "Test All",
      "type": "shell",
      "command": "uv",
      "args": ["run", "pytest", "tests/tests_all.py", "-v"],
      "group": {
        "kind": "build",
        "isDefault": false
      }
    },
    {
      "label": "Next Task",
      "type": "shell",
      "command": "uv",
      "args": ["run", "python", "utils/complete.py"],
      "group": {
        "kind": "build",
        "isDefault": false
      }
    }
  ]
}
